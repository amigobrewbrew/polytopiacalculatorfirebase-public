{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Dev Server",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/src"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Vitest: Current File",
            "program": "${workspaceFolder}/node_modules/.bin/vitest",
            "args": ["run", "${relativeFile}"],
            "console": "integratedTerminal"
        }
    ]
}

{
    "name": "polytopia-damage-calculator",
    "version": "0.2.0",
    "private": true,
    "type": "module",
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^9.0.0",
        "@mui/material": "^9.0.0",
        "firebase": "^12.12.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.0",
        "web-vitals": "^5.2.0"
    },
    "scripts": {
        "dev": "vite",
        "start": "vite",
        "prettier": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,html}\"",
        "prettier:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md,html}\"",
        "format": "npm run prettier",
        "build": "vite build",
        "preview": "vite preview",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "vitest run",
        "test:e2e": "npx playwright test",
        "eject": "echo 'eject script not supported'"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "engines": {
        "node": ">=22.0.0 <24.0.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint-config-prettier": "^10.1.8",
        "jsdom": "^29.0.2",
        "prettier": "^3.8.2",
        "typescript": "^6.0.2",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    }
}
